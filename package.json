{
  "name": "@camertron/garnet-js",
  "version": "0.1.0",
  "description": "The YARV virtual machine written in Javascript.",
  "main": "dist/garnet.js",
  "module": "dist/garnet.js",
  "repository": "camertron/garnet-js",
  "type": "module",
  "keywords": [
    "ruby",
    "virtual-machine"
  ],
  "author": "Cameron Dutro",
  "license": "MIT",
  "homepage": "https://github.com/camertron/garnet-js#readme",
  "bugs": {
    "url": "https://github.com/camertron/garnet-js/issues"
  },
  "files": [
    "/dist",
    "/src"
  ],
  "scripts": {
    "clean": "rimraf build dist",
    "build": "./scripts/build.sh",
    "build:release": "./scripts/build.sh --release",
    "clean-build": "npm run clean && npm run build",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --no-cache",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.2.17"
  },
  "devDependencies": {
    "@camertron/garnet-js": "./",
    "@garnet-js/encoding-euc-jp": "file:./packages/encoding-euc-jp",
    "@garnet-js/encoding-shift-jis": "file:./packages/encoding-shift-jis",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@ruby/prism": "^1.7.0",
    "@types/jest": "^29.5.8",
    "@types/node": "^25.9.3",
    "benchmarkify": "^3.0.0",
    "globals": "^15.1.0",
    "jest": "^29.7.0",
    "rimraf": "3.0.2",
    "rollup": "^2.79.0",
    "rollup-plugin-terser": "^7.0.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
